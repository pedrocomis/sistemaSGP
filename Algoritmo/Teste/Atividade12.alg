algoritmo "Nome do Programa"
var

numero1 , dobro , tercaparte : real

inicio
escreva("Digite um número para saber o dobro e sua terça parte:")
leia(numero1)
dobro <- numero1 * 2
escreval("O dobro do número ", numero1 , " é : ", dobro)
tercaparte <- numero1 / 3 
escreval("O terço do número ", numero1 , " é : " , tercaparte)

fimalgoritmo