algoritmo "Nome do Programa"
var
    num1: inteiro
    antecessor: inteiro
    sucessor: inteiro
inicio
    escreva("Digite um número:")
        leia(num1)
    antecessor <- num1 - 1
    sucessor <- num1 + 1
    escreval("O número digitado foi:" , num1)
    escreval("O antecessor do ", num1 ," é:" , antecessor)
    escreval("O sucessor do ", num1 ," é:", sucessor)
    

fimalgoritmo 